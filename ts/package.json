{
  "name": "agent-vfs",
  "version": "0.1.0",
  "description": "Persistent virtual filesystem for AI agents, backed by SQLite or Postgres",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./ai": {
      "import": "./dist/ai.js",
      "types": "./dist/ai.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle.js",
      "types": "./dist/drizzle.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "filesystem",
    "ai",
    "agents",
    "sqlite",
    "postgres",
    "memory",
    "tools",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johannesmichalke/agent-vfs.git"
  },
  "peerDependencies": {
    "ai": ">=4.0.0",
    "drizzle-orm": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
